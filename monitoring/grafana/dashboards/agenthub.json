{
  "title": "AgentHub",
  "uid": "agenthub-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Tokens / sec",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal" } }
        }
      },
      "targets": [
        {
          "expr": "sum by (direction) (rate(llm_tokens_used_total[2m]))",
          "legendFormat": "{{direction}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cost USD / hr",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6
        }
      },
      "targets": [
        {
          "expr": "sum by (provider, model) (rate(llm_cost_usd_total[2m])) * 3600",
          "legendFormat": "{{provider}} / {{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache Hit Ratio",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "semantic_cache_hit_ratio",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache Hit Ratio (rolling)",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "semantic_cache_hit_ratio",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "LLM Request Latency (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(llm_request_duration_seconds_bucket[2m])))",
          "legendFormat": "p50 {{provider}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(llm_request_duration_seconds_bucket[2m])))",
          "legendFormat": "p95 {{provider}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, provider) (rate(llm_request_duration_seconds_bucket[2m])))",
          "legendFormat": "p99 {{provider}}",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RAG Retrieval Latency (p50 / p95)",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(rag_retrieval_duration_seconds_bucket[2m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_retrieval_duration_seconds_bucket[2m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Embedding Latency (p50 / p95)",
      "gridPos": { "x": 8, "y": 14, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(embedding_duration_seconds_bucket[2m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(embedding_duration_seconds_bucket[2m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Total Tokens (all time)",
      "gridPos": { "x": 16, "y": 14, "w": 4, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(llm_tokens_used_total)",
          "legendFormat": "tokens",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Total Cost USD (all time)",
      "gridPos": { "x": 20, "y": 14, "w": 4, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(llm_cost_usd_total)",
          "legendFormat": "cost",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    }
  ]
}
